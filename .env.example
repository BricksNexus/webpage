# --- LLM for /api/feasibility (Zoning Consultant) ---
# Recommended: Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Aliases (same key): GOOGLE_API_KEY=  or  GOOGLE_GENERATIVE_AI_API_KEY=
# Model (default: gemini-2.0-flash). Examples: gemini-2.5-flash, gemini-2.0-flash-lite
# GEMINI_MODEL=gemini-2.0-flash

# Optional fallbacks if GEMINI_API_KEY is unset:
# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# ZONING_CONSULTANT_API_KEY=
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_SITE_URL=https://your-domain.vercel.app
# OPENROUTER_APP_TITLE=BricksNexus

# Direct OpenAI (used only if neither Gemini nor OpenRouter is set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Geocoding (optional on server: /api/property uses free Census + Nominatim if unset) ---
# For best accuracy / rate limits, set one of:
MAPBOX_ACCESS_TOKEN=
# GOOGLE_MAPS_GEOCODING_API_KEY=
# Optional: disable OSM Nominatim fallback (Census US-only remains)
# DISABLE_NOMINATIM_GEOCODE=1
# Nominatim requires a descriptive User-Agent (https://operations.osmfoundation.org/policies/nominatim/)
# NOMINATIM_USER_AGENT=YourApp/1.0 (contact@yourdomain.com)

# --- NYC: Geoclient + PLUTO (NYC Open Data Socrata) ---
# Register: https://developer.cityofnewyork.us/
NYC_GEOCLIENT_APP_ID=
NYC_GEOCLIENT_APP_KEY=
# Resource id from PLUTO/MapPLUTO dataset URL on data.cityofnewyork.us
NYC_PLUTO_SODA_DATASET_ID=
# Optional Socrata app token (higher rate limits)
# NYC_SODA_APP_TOKEN=

# --- Boston: Property Assessment (CKAN datastore) ---
# resource_id from data.boston.gov → Property Assessment → resource API
BOSTON_PROPERTY_ASSESSMENT_RESOURCE_ID=

# Optional: self-hosted or alternate Overpass instance
# OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# REGRID_API_KEY=

# --- ATTOM property data (for /api/nyc-property and /api/opportunity-report) ---
# Register at https://www.attomdata.com/
ATTOM_API_KEY=

# --- KV / Report persistence (for /api/opportunity-report) ---
# Production (Vercel): connect an Upstash Redis store via Vercel Integrations.
# The integration auto-sets these vars in your Vercel environment.
# Dev fallback: reports are stored as JSON files in .kv-store/ (no setup needed).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
